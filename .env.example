# LLM provider: anthropic (paid) | gemini (free) | groq (free)
LLM_PROVIDER=anthropic

# Anthropic (required when LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=your_key_here

# Google Gemini (required when LLM_PROVIDER=gemini)
GEMINI_API_KEY=your_key_here

# Groq (required when LLM_PROVIDER=groq)
GROQ_API_KEY=your_key_here

# Override specific models (optional — defaults per provider are sensible)
# EXTRACT_MODEL=claude-haiku-4-5-20251001
# ANSWER_MODEL=claude-sonnet-4-6

# Optional tuning
CONTEXT_BUDGET_TOKENS=6000
CACHE_TTL_SECONDS=86400
EMBEDDING_MODEL=all-MiniLM-L6-v2
